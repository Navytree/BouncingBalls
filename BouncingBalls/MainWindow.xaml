<Window x:Class="BouncingBalls.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:BouncingBalls"
        mc:Ignorable="d"
        Title="Moving balls fun!" Height="600" Width="1200">
    <Grid Background="#FFD4F9F3" Width="1200">
        <Canvas Name="ca" HorizontalAlignment="Center" Height="400" Margin="0,26,0,0" VerticalAlignment="Top" Width="925" Background="FloralWhite">
            <Ellipse Name="el" Height="50" Canvas.Left="50" Canvas.Top="50" Width="50" Fill="#FF98C4FF" RenderTransformOrigin="0.5,0.5" HorizontalAlignment="Left" VerticalAlignment="Top">
                <Ellipse.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform/>
                        <SkewTransform/>
                        <RotateTransform/>
                        <TranslateTransform X="10" Y="10"/>
                    </TransformGroup>
                </Ellipse.RenderTransform>
            </Ellipse>
        </Canvas>
        <Button x:Name="startBtn" Click="BtnStart_Click"  Content="Start" HorizontalAlignment="Left" Height="80" Margin="30,475,0,0" VerticalAlignment="Top" Width="190" Background="#FF38C6ED" FontSize="30" FontFamily="Comic Sans MS"/>
        <Button x:Name="stopBtn" Click="StopBtn_Click"   Content="Stop"  HorizontalAlignment="Left" Height="80" Margin="295,475,0,0" VerticalAlignment="Top" Width="190"  Background="#FF38C6ED" FontSize="30" FontFamily="Comic Sans MS"/>
        <Button x:Name="addBallBtn" Click="AddBallBtn_Click"   Content="Dodaj piłeczkę"  HorizontalAlignment="Left" Height="80" Margin="665,475,0,0" VerticalAlignment="Top" Width="235"  Background="#FF38C6ED" FontSize="30" FontFamily="Comic Sans MS"/>
        <Button x:Name="deleteBallBtn" Click="DeleteBallBtn_Click"   Content="Usuń piłeczkę"  HorizontalAlignment="Left" Height="80" Margin="943,475,0,0" VerticalAlignment="Top" Width="235"  Background="#FF38C6ED" FontSize="30" FontFamily="Comic Sans MS"/>

    </Grid>
</Window>
